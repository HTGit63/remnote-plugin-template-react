REMNOTE_BRIDGE_ALLOW_NO_TOKEN=0
REMNOTE_BRIDGE_HOST=127.0.0.1
REMNOTE_BRIDGE_WS_PORT=47391
REMNOTE_BRIDGE_MCP_PORT=47392
REMNOTE_BRIDGE_ALLOW_REMOTE=0
REMNOTE_BRIDGE_ALLOW_CORS=0
REMNOTE_BRIDGE_ALLOWED_ORIGINS=
