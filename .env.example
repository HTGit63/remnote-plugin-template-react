# Local companion server settings.
# Use a generated token and enter the same value in the RemNote plugin setting:
# Bridge Token.
REMNOTE_BRIDGE_TOKEN=
REMNOTE_BRIDGE_ALLOW_NO_TOKEN=0
REMNOTE_BRIDGE_HOST=127.0.0.1
REMNOTE_BRIDGE_SINGLE_PORT=0
REMNOTE_BRIDGE_PORT=47392
REMNOTE_BRIDGE_WS_PORT=47391
REMNOTE_BRIDGE_MCP_PORT=47392
REMNOTE_BRIDGE_WS_PATH=/remnote-bridge
REMNOTE_BRIDGE_MCP_PATH=/mcp
REMNOTE_BRIDGE_TOOL_PROFILE=full
REMNOTE_BRIDGE_ALLOW_REMOTE=0
REMNOTE_BRIDGE_ALLOW_CORS=0
REMNOTE_BRIDGE_ALLOWED_ORIGINS=
REMNOTE_BRIDGE_AUDIT_LOG=1
REMNOTE_BRIDGE_MAX_BODY_BYTES=131072
REMNOTE_BRIDGE_MAX_WS_MESSAGE_BYTES=2097152
# Reserved for future OAuth/pairing mode. Setting this to 1 intentionally fails startup today.
REMNOTE_BRIDGE_HOSTED_MODE=0
# Keep arbitrary-ID delete hidden. Focused/selected delete tools still require RemNote approval.
REMNOTE_BRIDGE_ENABLE_DELETE_TOOL=0
